BACKEND_URL=http://localhost:8000

# OpenTelemetry / OpenObserve
# Server-side (API routes / SSR)
OTEL_SERVICE_NAME=kaapi-frontend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:5080/api/default
OTEL_EXPORTER_OTLP_AUTH_HEADER=

# Browser-side (NEXT_PUBLIC_ prefix exposes to client bundle)
NEXT_PUBLIC_OTEL_ENABLED=true
NEXT_PUBLIC_OTEL_SERVICE_NAME=kaapi-frontend-browser
NEXT_PUBLIC_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:5080/api/default
NEXT_PUBLIC_OTEL_EXPORTER_OTLP_AUTH_HEADER=